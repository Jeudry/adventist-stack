# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno. Copiar a `.env` y completar.
#   cp .env.example .env
# El archivo `.env` real está en .gitignore: NUNCA se commitea.
# ─────────────────────────────────────────────────────────────

ENV=dev

# ── Base de datos (PostgreSQL) ──────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5433/adventist_stack?sslmode=disable
AUTO_MIGRATE=true

# ── Redis (cache + pub/sub de notificaciones) ───────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ─────────────────────────────────────────────────────
# GENERA UN SECRETO FUERTE:  openssl rand -base64 48
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=adventist-stack

# ── SMTP (correo) ───────────────────────────────────────────
# En dev apunta a MailHog (docker-compose): host=localhost port=1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@adventist-stack.local

# ── Gateway ─────────────────────────────────────────────────
GATEWAY_HTTP_PORT=8090
AUTH_GRPC_ADDR=localhost:50051
NOTIFICATIONS_GRPC_ADDR=localhost:50052
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# ── Puertos gRPC de los servicios ───────────────────────────
AUTH_GRPC_PORT=50051
NOTIFICATIONS_GRPC_PORT=50052
