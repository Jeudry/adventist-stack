{
  "$schema": "https://pgtools.dev/latest/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "safety": {
        // DROP TABLE es correcto y esperado en las migraciones .down.sql
        // (deshacen el CREATE del .up.sql), así que apagamos esta advertencia.
        "banDropTable": "off"
      }
    }
  }
}
